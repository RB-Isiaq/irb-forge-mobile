# Base URL for the IRB Forge backend API.
# Android emulator: use http://10.0.2.2:3000/api instead of localhost.
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Google OAuth client IDs, from Google Cloud Console > APIs & Services > Credentials.
# Create one OAuth client per platform (iOS, Android, Web). The "Web" client ID also
# doubles as the audience the backend should verify the id_token against.
# Until these are set, the "Continue with Google" button is hidden (see useGoogleSignInRequest).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

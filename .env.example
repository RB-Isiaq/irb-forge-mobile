# Base URL for the IRB Forge backend API.
# Android emulator: use http://10.0.2.2:3000/api instead of localhost.
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Google OAuth, via @react-native-google-signin/google-signin (Google's native SDK —
# Credential Manager on Android, native Google Sign-In on iOS). Google no longer allows
# custom-scheme redirect URIs on "Web application" clients, which is what ruled out a
# browser/PKCE-based flow here — the native SDK has no redirect URI at all, so this is
# the durable approach. Until EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID is set, the "Continue
# with Google" button is hidden (see src/lib/auth/google.ts).
#
# WEB client (Cloud Console > Credentials > Create > OAuth client ID > Web application):
# reuse the same one irb-forge-fe already uses — no redirect URI needed for this purpose,
# it's only used as the audience for the id_token, verified the same way on the backend.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# IOS client (Create > OAuth client ID > iOS, Bundle ID: com.irbforge.mobile).
# Required for GoogleSignin.configure() on iOS — without it, sign-in fails on iOS only.
# app.config.ts also derives the native iosUrlScheme (the reversed client ID) from this
# value at prebuild time, so there is no separate scheme to set or keep in sync.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ANDROID client (Create > OAuth client ID > Android, Package name: com.irbforge.mobile,
# SHA-1: from `npx eas credentials` -> Android -> Keystore, or your local debug keystore).
# Not referenced directly in code — Google Play Services on the device matches it
# automatically by package name + signing cert. Must exist in Console or sign-in fails
# on Android with a DEVELOPER_ERROR.
